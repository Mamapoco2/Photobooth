# Snap Camera Kit (optional) — https://developers.snap.com/camera-kit/integrate-sdk/web/web-configuration
# Create an API token in https://kit.snapchat.com/manage
VITE_SNAP_CAMERA_KIT_API_TOKEN=your_api_token_here
# Lens Group ID(s) from Lens Scheduler — comma-separated to merge multiple groups
# (e.g. face filters, floating hearts, masks in one or more groups you own).
# VITE_SNAP_LENS_GROUP_IDS=00000000-0000-4000-8000-000000000001,00000000-0000-4000-8000-000000000002
